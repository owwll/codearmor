# HuggingFace
HF_API_KEY=hf_your_key_here
HF_PRIMARY_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_FALLBACK_MODEL=HuggingFaceH4/zephyr-7b-beta
HF_REQUEST_TIMEOUT_MS=15000

# Server
BACKEND_PORT=3847
ADMIN_PORT=4000

# Auth
JWT_SECRET=change-this-to-a-long-random-string-minimum-64-chars

# Database
DATABASE_URL=postgresql://neondb_owner:npg_YOUR_PASSWORD@ep-YOUR-PROJECT-ID.us-east-2.aws.neon.tech/neondb?sslmode=require

# ArmorIQ (use 'mock' for development without real credentials)
ARMORIQ_API_KEY=mock
ARMORIQ_ENDPOINT=https://api.armoriq.io/v1

# ArmorClaw (use 'mock' for development)
ARMORCLAW_API_KEY=mock
ARMORCLAW_ENDPOINT=https://api.armorclaw.io/v1

# Admin account (set before first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisPassword123!

# Scan settings
MAX_FILE_SIZE_KB=500
MAX_FILES_PER_SCAN=300
SCAN_TIMEOUT_MS=60000
DEV_MODE=true
LOG_LEVEL=info
