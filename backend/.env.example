# HuggingFace
HF_API_KEY=hf_your_key_here
HF_PRIMARY_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_FALLBACK_MODEL=HuggingFaceH4/zephyr-7b-beta
HF_REQUEST_TIMEOUT_MS=15000

# Server
BACKEND_PORT=3847
ADMIN_PORT=4000

# Auth
JWT_SECRET=change-this-to-a-long-random-string-minimum-64-chars

# Database
DATABASE_URL=postgresql://neondb_owner:npg_YOUR_PASSWORD@ep-YOUR-PROJECT-ID.us-east-2.aws.neon.tech/neondb?sslmode=require

# ArmorIQ (use 'mock' for development without real credentials)
# Get these values from your ArmorIQ Platform dashboard → Settings → API Keys
ARMORIQ_API_KEY=mock
# Base URL — the SDK manages path routing internally; do NOT add /v1 suffix
ARMORIQ_ENDPOINT=https://api.armoriq.ai
ARMORIQ_USER_ID=your-user-id-from-dashboard
ARMORIQ_AGENT_ID=codearmor-orchestrator
# MCP server name registered in ArmorIQ Platform → MCPs
ARMORIQ_MCP_NAME=codearmor-mcp
# Comma-separated list of agent names registered in ArmorIQ Platform → Agents
# (used for internal routing in delegate.ts scope maps — keep as names)
# Order must match the agent-scope mapping in delegate.ts
ARMORIQ_AGENTS=route-analyst,auth-inspector,injection-hunter,data-flow-tracer,config-auditor,xss-scanner,csrf-scanner,file-security,api-security,business-logic,crypto-auditor
# Agent UUIDs from ArmorIQ Platform (in same order as ARMORIQ_AGENTS)
# Used in plan steps for ArmorIQ IAP identification
# Fill with UUIDs from Agents dashboard after registration
ARMORIQ_AGENT_IDS=<uuid1>,<uuid2>,<uuid3>,<uuid4>,<uuid5>,<uuid6>,<uuid7>,<uuid8>,<uuid9>,<uuid10>,<uuid11>

# ArmorClaw (use 'mock' for development)
ARMORCLAW_API_KEY=mock
ARMORCLAW_ENDPOINT=https://api.armorclaw.io/v1

# Admin account (set before first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisPassword123!

# Scan settings
MAX_FILE_SIZE_KB=500
MAX_FILES_PER_SCAN=300
SCAN_TIMEOUT_MS=60000
DEV_MODE=true
LOG_LEVEL=info
