{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "path": "extension",
      "problemMatcher": {
        "owner": "typescript",
        "fileLocation": ["relative", "${workspaceFolder}/extension"],
        "pattern": {
          "regexp": "^\\s*(.*):(\\d+):(\\d+):\\s*(warning|error):\\s*(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[watch\\] build started",
          "endsPattern": "^\\[watch\\] build finished"
        }
      },
      "isBackground": true,
      "label": "npm: watch - extension"
    },
    {
      "type": "npm",
      "script": "watch:webview",
      "path": "extension",
      "problemMatcher": {
        "owner": "typescript",
        "fileLocation": ["relative", "${workspaceFolder}/extension"],
        "pattern": {
          "regexp": "^\\s*(.*):(\\d+):(\\d+):\\s*(warning|error):\\s*(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[watch\\] build started",
          "endsPattern": "^\\[watch\\] build finished"
        }
      },
      "isBackground": true,
      "label": "npm: watch - webview"
    },
    {
      "label": "watch-all",
      "dependsOn": [
        "npm: watch - extension",
        "npm: watch - webview"
      ],
      "problemMatcher": []
    }
  ]
}
